    {
      "parameters": {
        "jsCode": "const tts = $('Prepare TTS Text').first().json;\nconst input = $('Set Audio Generation Context').first().json;\nconst currentItem = $input.first();\n\nconst binaryKeys = Object.keys(currentItem.binary || {});\n\nif (binaryKeys.length === 0) {\n  throw new Error('No binary audio found from OpenAI TTS node');\n}\n\n// Normalmente será \"data\", pero lo detectamos por seguridad.\nconst sourceBinaryKey = binaryKeys[0];\nconst sourceBinary = currentItem.binary[sourceBinaryKey];\n\nconst safeTitle = (tts.title || 'untitled')\n  .toLowerCase()\n  .normalize('NFD')\n  .replace(/[\\u0300-\\u036f]/g, '')\n  .replace(/[^a-z0-9]+/g, '-')\n  .replace(/^-+|-+$/g, '')\n  .slice(0, 60);\n\nconst fileName = `voiceover_part_001_${safeTitle}.mp3`;\n\nreturn {\n  json: {\n    script_id: tts.script_id,\n    video_id: input.video_id,\n    idea_id: tts.idea_id,\n    research_brief_id: tts.research_brief_id,\n\n    drive_root_folder_id: input.drive_root_folder_id,\n\n    file_name: fileName,\n    mime_type: sourceBinary.mimeType || 'audio/mpeg',\n    file_extension: sourceBinary.fileExtension || 'mp3',\n    file_size_bytes: sourceBinary.fileSize || sourceBinary.bytes || null,\n\n    asset_type: 'voiceover_audio',\n    provider: 'openai',\n    repository: 'google_drive',\n\n    model: tts.model,\n    voice: tts.voice,\n    response_format: tts.response_format,\n    full_script_length: tts.full_script_length,\n    was_truncated: tts.was_truncated,\n\n    folder_type: 'audio',\n    folder_path_logical: `videos/${input.video_id}/03_audio`,\n\n    // Este será el nombre del binary property para el siguiente nodo.\n    binary_property_name: 'data'\n  },\n\n  // Normalizamos el binario para que el siguiente nodo lo reciba como \"data\".\n  binary: {\n    data: {\n      ...sourceBinary,\n      fileName,\n      mimeType: sourceBinary.mimeType || 'audio/mpeg',\n      fileExtension: sourceBinary.fileExtension || 'mp3'\n    }\n  }\n};"
      },
