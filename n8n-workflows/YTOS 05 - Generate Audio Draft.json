    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const script = $json;\n\nif (!script.script_text) {\n  throw new Error('Missing script_text');\n}\n\n// Extrae solo el bloque principal para narración.\n// Evita leer títulos técnicos, scene breakdown, visual notes y shorts.\nlet text = script.script_text;\n\nconst fullScriptMarker = '# Full Script';\nconst sceneMarker = '# Scene Breakdown';\n\nif (text.includes(fullScriptMarker)) {\n  text = text.split(fullScriptMarker)[1];\n}\n\nif (text.includes(sceneMarker)) {\n  text = text.split(sceneMarker)[0];\n}\n\ntext = text\n  .replace(/\\*\\*/g, '')\n  .replace(/#/g, '')\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .trim();\n\nconst maxChars = 3900;\n\n// Para el MVP generamos un primer audio corto si el texto excede el límite.\n// Luego haremos chunking automático.\nconst ttsText = text.length > maxChars ? text.slice(0, maxChars) : text;\n\nreturn {\n  json: {\n    script_id: script.id,\n    idea_id: script.idea_id,\n    research_brief_id: script.research_brief_id,\n    title: script.title,\n    tts_text: ttsText,\n    full_script_length: text.length,\n    was_truncated: text.length > maxChars,\n    voice: 'onyx',\n    model: 'gpt-4o-mini-tts',\n    response_format: 'mp3'\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        -848
      ],
      "id": "614df9b3-00c9-46b5-ade4-eebb317defcd",
      "name": "Prepare TTS Text"
